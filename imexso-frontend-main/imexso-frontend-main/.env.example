# Laravel API (Next.js rewrites proxy /api and /sanctum to this host)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Registration reCAPTCHA (optional; must match backend if RECAPTCHA_ENABLED=true)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Optional: CarLab 360 base URL for embeds
# NEXT_PUBLIC_CARLAB_360_BASE_URL=
